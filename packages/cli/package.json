{
  "name": "@anchored-spec/cli",
  "version": "0.1.0",
  "description": "CLI for the Anchored Spec framework — init, create, verify, generate, status",
  "type": "module",
  "bin": {
    "anchored-spec": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "check-types": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anchored-spec/core": "workspace:*",
    "commander": "^13.1.0",
    "chalk": "^5.4.1",
    "ora": "^8.2.0",
    "glob": "^11.0.2"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^22.15.0",
    "vitest": "^3.2.1",
    "typescript": "^5.9.2"
  }
}
