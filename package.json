{
  "name": "anchored-spec",
  "version": "0.4.1",
  "description": "Backstage-aligned, spec-as-source architecture control plane — author entities in version control, validate, trace, detect drift, and analyze impact from one CLI for humans and AI agents.",
  "type": "module",
  "bin": {
    "anchored-spec": "./dist/cli/index.js"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./cli": {
      "import": "./dist/cli/index.js",
      "require": "./dist/cli/index.cjs"
    },
    "./schemas/*": "./dist/ea/schemas/*",
    "./ea/schemas/*": "./dist/ea/schemas/*",
    "./resolvers/typescript-ast": {
      "import": {
        "types": "./dist/resolvers/typescript-ast.d.ts",
        "default": "./dist/resolvers/typescript-ast.js"
      },
      "require": {
        "types": "./dist/resolvers/typescript-ast.d.cts",
        "default": "./dist/resolvers/typescript-ast.cjs"
      }
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "docs/workflows/agent-guide.md",
    "LICENSE"
  ],
  "scripts": {
    "prepare": "npm run build",
    "build": "tsup && cp -r src/ea/schemas dist/ea/",
    "check-types": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:harness": "vitest run src/ea/__tests__/repository-harness.test.ts",
    "task:start": "node ./scripts/task-start.mjs",
    "task:verify": "node ./scripts/task-verify.mjs",
    "task:check": "node ./scripts/task-check.mjs",
    "task:close": "node ./scripts/task-close.mjs",
    "verify": "pnpm run task:check && pnpm run spec:validate && pnpm run spec:trace && pnpm run test:harness && tsc && vitest run && eslint .",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "prepublishOnly": "pnpm verify",
    "spec:validate": "node ./dist/cli/index.js validate",
    "spec:verify": "node ./dist/cli/index.js verify",
    "spec:graph": "node ./dist/cli/index.js graph --format mermaid",
    "spec:trace": "node ./dist/cli/index.js trace --summary",
    "spec:drift": "node ./dist/cli/index.js drift",
    "spec:report": "node ./dist/cli/index.js report"
  },
  "dependencies": {
    "@backstage/catalog-model": "^1.8.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "mdast-util-to-string": "^4.0.0",
    "minimatch": "^10.0.1",
    "ora": "^8.2.0",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/mdast": "^4.0.4",
    "@types/node": "^22.15.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-only-warn": "^1.1.0",
    "prettier": "^3.7.4",
    "tree-sitter-javascript": "^0.25.0",
    "tree-sitter-typescript": "^0.23.2",
    "ts-morph": "^27.0.2",
    "tsup": "^8.5.1",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.50.0",
    "vitest": "^3.2.1",
    "web-tree-sitter": "^0.26.8"
  },
  "keywords": [
    "architecture",
    "architecture-as-code",
    "spec-as-source",
    "backstage",
    "software-catalog",
    "drift-detection",
    "traceability",
    "impact-analysis",
    "ai-agents",
    "llm-context",
    "devtools",
    "cli",
    "adr",
    "governance"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/idvexchange/anchored-spec.git"
  },
  "bugs": {
    "url": "https://github.com/idvexchange/anchored-spec/issues"
  },
  "homepage": "https://github.com/idvexchange/anchored-spec#readme",
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "ts-morph": ">=23.0.0"
  },
  "peerDependenciesMeta": {
    "ts-morph": {
      "optional": true
    }
  }
}
