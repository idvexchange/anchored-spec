{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://anchored-spec.dev/schemas/config-v1.schema.json",
  "title": "Anchored Spec Configuration",
  "description": "Top-level configuration for anchored-spec. Supports schema versions 1.0, 1.1, and 1.2.",
  "type": "object",
  "required": ["schemaVersion", "rootDir"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "type": "string",
      "enum": ["1.0", "1.1", "1.2"],
      "description": "Config format version."
    },
    "rootDir": {
      "type": "string",
      "default": "docs",
      "description": "Root directory for EA entities."
    },
    "generatedDir": {
      "type": "string",
      "default": "docs/generated",
      "description": "Directory for generated output files."
    },
    "idPrefix": {
      "type": ["string", "null"],
      "default": null,
      "description": "Optional organizational prefix for entity IDs (e.g., \"acme\")."
    },
    "domains": {
      "description": "Per-domain paths in 1.0 or semantic domain labels in 1.1+.",
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "systems": { "type": "string" },
            "delivery": { "type": "string" },
            "data": { "type": "string" },
            "information": { "type": "string" },
            "business": { "type": "string" },
            "transitions": { "type": "string" }
          },
          "additionalProperties": false
        },
        {
          "type": "array",
          "items": { "type": "string" }
        }
      ]
    },
    "docs": {
      "type": "object",
      "description": "Structured docs configuration for schema versions 1.1 and 1.2.",
      "properties": {
        "structure": { "type": "string" },
        "scanDirs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "rootDocs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "sections": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "title", "path", "kind"],
            "properties": {
              "id": { "type": "string" },
              "title": { "type": "string" },
              "path": { "type": "string" },
              "kind": { "type": "string" },
              "domains": {
                "type": "array",
                "items": { "type": "string" }
              }
            },
            "additionalProperties": false
          }
        },
        "templates": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "catalog": {
      "type": "object",
      "description": "Catalog synthesis configuration introduced in schema version 1.2.",
      "properties": {
        "bootstrap": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "profile": { "type": "string" },
            "outputMode": {
              "type": "string",
              "enum": ["curated", "expanded"]
            },
            "writeTarget": { "type": "string" },
            "minConfidence": { "type": "number" },
            "maxTopLevelComponents": { "type": "number" },
            "include": {
              "type": "object",
              "additionalProperties": { "type": "boolean" }
            },
            "defaults": {
              "type": "object",
              "properties": {
                "ownerRef": { "type": "string" },
                "ownerKind": { "type": "string" },
                "ownerType": { "type": "string" },
                "ownerUnitType": { "type": "string" },
                "componentLifecycle": { "type": "string" },
                "apiLifecycle": { "type": "string" },
                "capabilityLevel": { "type": "number" }
              },
              "additionalProperties": false
            },
            "evidence": {
              "type": "object",
              "properties": {
                "sources": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["type"],
                    "properties": {
                      "type": { "type": "string" },
                      "enabled": { "type": "boolean" },
                      "weight": { "type": "number" }
                    },
                    "additionalProperties": false
                  }
                }
              },
              "additionalProperties": false
            },
            "mappings": {
              "type": "object",
              "additionalProperties": true
            },
            "naming": {
              "type": "object",
              "additionalProperties": true
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "resolvers": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string", "description": "Built-in resolver name (e.g. openapi, tree-sitter)." },
          "path": { "type": "string", "description": "Module path to a custom resolver." },
          "cacheTTL": { "type": "number", "description": "Cache TTL in seconds." },
          "options": { "type": "object", "description": "Resolver-specific options." }
        },
        "additionalProperties": false
      },
      "default": [],
      "description": "Configured resolver plugins. Use 'name' for built-in resolvers or 'path' for custom modules."
    },
    "generators": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "outputDir"],
        "properties": {
          "path": { "type": "string", "description": "Module path to the generator." },
          "outputDir": { "type": "string", "description": "Output directory." },
          "options": { "type": "object", "description": "Generator-specific options." }
        },
        "additionalProperties": false
      },
      "default": [],
      "description": "Configured generator plugins."
    },
    "evidenceSources": {
      "type": "array",
      "items": { "type": "string" },
      "default": [],
      "description": "Evidence source paths."
    },
    "cache": {
      "type": "object",
      "properties": {
        "dir": { "type": "string", "default": ".anchored-spec/cache", "description": "Cache directory." },
        "defaultTTL": { "type": "number", "default": 3600, "description": "Default TTL in seconds." }
      },
      "additionalProperties": false,
      "description": "Resolver cache settings."
    },
    "quality": {
      "type": "object",
      "properties": {
        "requireOwners": { "type": "boolean", "default": true },
        "requireSummary": { "type": "boolean", "default": true },
        "requireRelations": { "type": "boolean", "default": false },
        "requireAnchors": { "type": "boolean", "default": false },
        "strictMode": { "type": "boolean", "default": false },
        "rules": {
          "type": "object",
          "additionalProperties": { "enum": ["error", "warning", "info", "off"] }
        }
      },
      "additionalProperties": false,
      "description": "Quality rule settings."
    },
    "sourceRoots": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Source code root directories for anchor resolution."
    },
    "sourceGlobs": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Source code glob patterns for anchor resolution."
    },
    "sourceAnnotations": {
      "type": "object",
      "description": "Source file annotation scanning configuration for trace integrity.",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable scanning source files for @anchored-spec annotations."
        },
        "sourceRoots": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Source directories to scan (overrides top-level sourceRoots for annotations)."
        },
        "sourceGlobs": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Glob patterns for source files (overrides top-level sourceGlobs for annotations)."
        }
      },
      "additionalProperties": false
    },
    "plugins": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Plugin module paths."
    },
    "exclude": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Glob patterns for files to exclude from entity loading."
    },
    "driftResolvers": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Pluggable drift resolver module paths."
    },
    "hooks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["event", "run"],
        "properties": {
          "event": { "type": "string", "description": "Hook event name." },
          "run": { "type": "string", "description": "Command to run." }
        },
        "additionalProperties": false
      },
      "description": "Lifecycle hooks."
    },
    "testMetadata": {
      "type": "object",
      "properties": {
        "testGlobs": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Glob patterns for test files."
        },
        "requirementPattern": {
          "oneOf": [
            { "type": "string" },
            { "type": "array", "items": { "type": "string" } }
          ],
          "description": "Regex pattern(s) to extract entity IDs from test files."
        }
      },
      "additionalProperties": false,
      "description": "Test metadata linking configuration."
    },
    "workflowPolicyPath": {
      "type": "string",
      "default": ".anchored-spec/policy.json",
      "description": "Path to workflow policy file."
    },
    "customChangeTypes": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Custom change types beyond built-in types."
    },
    "versionPolicy": {
      "type": "object",
      "description": "Version compatibility policy enforcement configuration.",
      "properties": {
        "defaultCompatibility": {
          "type": "string",
          "enum": ["backward-only", "full", "breaking-allowed", "frozen"],
          "default": "breaking-allowed",
          "description": "Default compatibility mode for all entities."
        },
        "perSchema": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "compatibility": {
                "type": "string",
                "enum": ["backward-only", "full", "breaking-allowed", "frozen"]
              },
              "deprecationWindow": {
                "type": "string",
                "pattern": "^\\d+(d|m|y)$",
                "description": "Minimum time in deprecated state before removal (e.g., '90d', '6m')."
              }
            },
            "additionalProperties": false
          },
          "description": "Per-schema compatibility policy overrides."
        },
        "perDomain": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "compatibility": {
                "type": "string",
                "enum": ["backward-only", "full", "breaking-allowed", "frozen"]
              },
              "deprecationWindow": {
                "type": "string",
                "pattern": "^\\d+(d|m|y)$"
              }
            },
            "additionalProperties": false
          },
          "description": "Per-domain compatibility policy overrides."
        }
      },
      "additionalProperties": false
    },
    "entityMode": {
      "type": "string",
      "enum": ["manifest", "inline"],
      "description": "Entity storage mode: 'manifest' (multi-doc Backstage YAML) or 'inline' (Backstage YAML frontmatter in markdown)."
    },
    "manifestPath": {
      "type": "string",
      "default": "catalog-info.yaml",
      "description": "Path to the manifest file (relative to project root). Used when entityMode is 'manifest'."
    },
    "catalogDir": {
      "type": "string",
      "default": "catalog",
      "description": "Directory containing individual Backstage entity YAML files. Used when entityMode is 'manifest' with split files."
    },
    "inlineDocDirs": {
      "type": "array",
      "items": { "type": "string" },
      "default": ["docs"],
      "description": "Directories containing markdown docs with Backstage YAML frontmatter. Used when entityMode is 'inline'."
    }
  }
}
