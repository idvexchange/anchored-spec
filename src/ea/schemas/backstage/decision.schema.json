{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://anchored-spec.dev/schemas/backstage/decision.schema.json",
  "title": "Anchored Spec — Decision Entity",
  "description": "An architectural decision record (ADR).",
  "type": "object",
  "properties": {
    "apiVersion": { "const": "anchored-spec.dev/v1alpha1" },
    "kind": { "const": "Decision" },
    "spec": {
      "type": "object",
      "required": ["owner"],
      "properties": {
        "status": { "type": "string", "description": "Decision status (e.g., proposed, accepted, superseded, deprecated)." },
        "owner": { "type": "string", "description": "Owner entity reference." },
        "decision": { "type": "string", "description": "The decision statement." },
        "context": { "type": "string", "description": "Context and background." },
        "rationale": { "type": "string", "description": "Rationale for the decision." },
        "alternatives": { "type": "array", "items": { "type": "string" }, "description": "Alternatives considered." },
        "dependsOn": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    }
  }
}
