{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://anchored-spec.dev/schemas/backstage/transition-plan.schema.json",
  "title": "Anchored Spec — TransitionPlan Entity",
  "description": "A transition plan or migration wave.",
  "allOf": [{ "$ref": "https://anchored-spec.dev/schemas/backstage/entity-envelope.schema.json" }],
  "properties": {
    "apiVersion": { "const": "anchored-spec.dev/v1alpha1" },
    "kind": { "const": "TransitionPlan" },
    "spec": {
      "type": "object",
      "required": ["owner"],
      "properties": {
        "type": { "type": "string", "description": "Subtype (e.g., transition-plan, migration-wave)." },
        "status": { "type": "string" },
        "owner": { "type": "string" },
        "dependsOn": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    }
  }
}
