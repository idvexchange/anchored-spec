{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://anchored-spec.dev/schemas/backstage/exchange.schema.json",
  "title": "Anchored Spec — Exchange Entity",
  "description": "An information exchange or integration between systems.",
  "allOf": [{ "$ref": "https://anchored-spec.dev/schemas/backstage/entity-envelope.schema.json" }],
  "properties": {
    "apiVersion": { "const": "anchored-spec.dev/v1alpha1" },
    "kind": { "const": "Exchange" },
    "spec": {
      "type": "object",
      "required": ["owner"],
      "properties": {
        "type": { "type": "string", "description": "Exchange type (e.g., information-exchange, integration)." },
        "status": { "type": "string" },
        "owner": { "type": "string" },
        "dependsOn": { "type": "array", "items": { "type": "string" } },
        "providesApis": { "type": "array", "items": { "type": "string" } },
        "consumesApis": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    }
  }
}
