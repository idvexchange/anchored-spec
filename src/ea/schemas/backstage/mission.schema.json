{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://anchored-spec.dev/schemas/backstage/mission.schema.json",
  "title": "Anchored Spec — Mission Entity",
  "description": "A mission statement or policy objective.",
  "type": "object",
  "properties": {
    "apiVersion": { "const": "anchored-spec.dev/v1alpha1" },
    "kind": { "const": "Mission" },
    "spec": {
      "type": "object",
      "required": ["owner"],
      "properties": {
        "type": { "type": "string", "description": "Subtype (e.g., mission, policy-objective)." },
        "status": { "type": "string" },
        "owner": { "type": "string" },
        "dependsOn": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    }
  }
}
