{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://anchored-spec.dev/schemas/ea/entity-base.schema.json",
  "title": "Anchored Spec — EA Artifact Base",
  "description": "The unified base shape shared by all EA entities. Every schema profile extends this with additional schema-specific fields.",
  "type": "object",
  "required": [
    "id",
    "schemaVersion",
    "kind",
    "title",
    "status",
    "summary",
    "owners",
    "confidence"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "description": "JSON Schema reference for editor validation"
    },
    "id": {
      "type": "string",
      "minLength": 3,
      "description": "Artifact identifier: {domain}/{KIND_PREFIX}-{slug} or {KIND_PREFIX}-{slug}"
    },
    "schemaVersion": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version of this artifact's content schema (team-managed)"
    },
    "kind": {
      "type": "string",
      "minLength": 1,
      "description": "Kind discriminator. Determines which extended fields apply."
    },
    "title": {
      "type": "string",
      "minLength": 3,
      "maxLength": 200,
      "description": "Human-readable title"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "planned",
        "active",
        "shipped",
        "deprecated",
        "retired",
        "deferred"
      ],
      "description": "Lifecycle status"
    },
    "summary": {
      "type": "string",
      "minLength": 10,
      "description": "Human-readable summary of what this artifact represents"
    },
    "owners": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1,
      "description": "Team or individual owners"
    },
    "confidence": {
      "type": "string",
      "enum": ["declared", "observed", "inferred"],
      "description": "How this artifact's information was established"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Freeform tags for filtering and grouping"
    },
    "relations": {
      "type": "array",
      "items": {
        "$ref": "https://anchored-spec.dev/schemas/ea/relation.schema.json"
      },
      "description": "Typed directional relations to other artifacts"
    },
    "anchors": {
      "$ref": "https://anchored-spec.dev/schemas/ea/anchors.schema.json",
      "description": "Anchor points to observable code/infra/APIs"
    },
    "traceRefs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path"],
        "properties": {
          "path": {
            "type": "string",
            "description": "Path to external document, URL, or artifact ID"
          },
          "role": {
            "type": "string",
            "enum": [
              "specification",
              "evidence",
              "rationale",
              "context",
              "implementation",
              "test"
            ]
          },
          "label": {
            "type": "string",
            "description": "Human-readable label"
          }
        },
        "additionalProperties": false
      },
      "description": "Trace links to external documents, evidence, rationale"
    },
    "risk": {
      "type": "object",
      "properties": {
        "level": {
          "type": "string",
          "enum": ["low", "medium", "high", "critical"]
        },
        "description": { "type": "string" },
        "mitigations": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "required": ["level"],
      "additionalProperties": false,
      "description": "Risk assessment metadata"
    },
    "compliance": {
      "type": "object",
      "properties": {
        "frameworks": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Compliance frameworks: SOC2, HIPAA, PCI-DSS"
        },
        "controls": {
          "type": "array",
          "items": { "type": "string" },
          "description": "References to control artifact IDs"
        },
        "lastAuditedAt": {
          "type": "string",
          "description": "ISO 8601 timestamp"
        },
        "nextAuditDue": {
          "type": "string",
          "description": "ISO 8601 timestamp"
        }
      },
      "additionalProperties": false,
      "description": "Compliance metadata"
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true,
      "description": "Extensible metadata for plugins and custom tooling"
    }
  },
  "additionalProperties": true
}
