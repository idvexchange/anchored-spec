{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://anchored-spec.dev/schemas/ea/process.schema.json",
  "title": "Anchored Spec — EA Process",
  "description": "A business process with steps, owner, and automation details.",
  "allOf": [
    { "$ref": "https://anchored-spec.dev/schemas/ea/entity-base.schema.json" }
  ],
  "properties": {
    "kind": { "const": "process" },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "name": { "type": "string", "minLength": 1 },
          "description": { "type": "string" },
          "actor": { "type": "string" },
          "systemRef": { "type": "string" },
          "automated": { "type": "boolean" }
        },
        "additionalProperties": false
      },
      "description": "Process steps"
    },
    "implementsCapabilities": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Capabilities this process implements"
    },
    "trigger": { "type": "string", "description": "What triggers this process" },
    "outcome": { "type": "string", "description": "Expected outcome" },
    "frequency": { "type": "string", "description": "How often this process runs" },
    "processOwner": { "type": "string", "description": "Process owner" },
    "regulated": { "type": "boolean", "description": "Whether this process is regulated" }
  }
}
