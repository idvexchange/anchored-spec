{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://anchored-spec.dev/schemas/ea/target.schema.json",
  "title": "Anchored Spec — EA Target",
  "description": "A desired future architecture state with success metrics.",
  "allOf": [
    { "$ref": "https://anchored-spec.dev/schemas/ea/entity-base.schema.json" }
  ],
  "required": ["scope", "effectiveBy", "entityRefs"],
  "properties": {
    "kind": { "const": "target" },
    "scope": {
      "type": "object",
      "required": ["description"],
      "properties": {
        "domains": {
          "type": "array",
          "items": { "type": "string", "enum": ["systems", "delivery", "data", "information", "business", "transitions"] },
          "description": "EA domains covered by this target"
        },
        "kinds": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Entity kinds included"
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Tags to filter included entities"
        },
        "description": { "type": "string", "minLength": 1, "description": "Scope description" }
      },
      "additionalProperties": false
    },
    "effectiveBy": { "type": "string", "description": "ISO 8601 date by which this target should be achieved" },
    "entityRefs": {
      "type": "array",
      "items": { "type": "string" },
      "description": "IDs of entities in the target state"
    },
    "principles": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Architecture principles guiding this target"
    },
    "successMetrics": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "metric", "target"],
        "properties": {
          "id": { "type": "string" },
          "metric": { "type": "string" },
          "target": { "type": "string" },
          "currentValue": { "type": "string" }
        },
        "additionalProperties": false
      },
      "description": "Measurable success criteria"
    }
  }
}
