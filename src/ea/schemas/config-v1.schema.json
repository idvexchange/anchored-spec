{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://anchored-spec.dev/schemas/config-v1.schema.json",
  "title": "Anchored Spec Configuration",
  "description": "Top-level configuration for anchored-spec schema versions 1.0 and 1.1.",
  "type": "object",
  "required": ["schemaVersion", "rootDir"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "type": "string",
      "enum": ["1.0", "1.1"],
      "description": "Config format version."
    },
    "rootDir": {
      "type": "string",
      "default": "docs",
      "description": "Root directory for EA docs and outputs."
    },
    "generatedDir": {
      "type": "string",
      "default": "docs/generated",
      "description": "Directory for generated output files."
    },
    "idPrefix": {
      "type": ["string", "null"],
      "default": null,
      "description": "Optional organizational prefix for entity IDs."
    },
    "domains": {
      "description": "In 1.0, a domain-to-path map. In 1.1, a semantic domain list.",
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "systems": { "type": "string" },
            "delivery": { "type": "string" },
            "data": { "type": "string" },
            "information": { "type": "string" },
            "business": { "type": "string" },
            "transitions": { "type": "string" }
          },
          "additionalProperties": false
        },
        {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        }
      ]
    },
    "docs": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "structure": {
          "type": "string",
          "description": "Named docs scaffold profile."
        },
        "scanDirs": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1,
          "description": "Directories scanned recursively by doc-aware commands."
        },
        "rootDocs": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Top-level framing documents."
        },
        "sections": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "title", "path", "kind"],
            "additionalProperties": false,
            "properties": {
              "id": { "type": "string" },
              "title": { "type": "string" },
              "path": { "type": "string" },
              "kind": { "type": "string" },
              "domains": {
                "type": "array",
                "items": { "type": "string" },
                "uniqueItems": true
              }
            }
          }
        },
        "templates": {
          "type": "object",
          "additionalProperties": { "type": "string" },
          "description": "Default section id by create-doc type."
        }
      }
    },
    "resolvers": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "path": { "type": "string" },
          "cacheTTL": { "type": "number" },
          "options": { "type": "object" }
        },
        "additionalProperties": false
      },
      "default": []
    },
    "generators": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "outputDir"],
        "properties": {
          "path": { "type": "string" },
          "outputDir": { "type": "string" },
          "options": { "type": "object" }
        },
        "additionalProperties": false
      },
      "default": []
    },
    "evidenceSources": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "cache": {
      "type": "object",
      "properties": {
        "dir": { "type": "string", "default": ".anchored-spec/cache" },
        "defaultTTL": { "type": "number", "default": 3600 }
      },
      "additionalProperties": false
    },
    "quality": {
      "type": "object",
      "properties": {
        "requireOwners": { "type": "boolean", "default": true },
        "requireSummary": { "type": "boolean", "default": true },
        "requireRelations": { "type": "boolean", "default": false },
        "requireAnchors": { "type": "boolean", "default": false },
        "strictMode": { "type": "boolean", "default": false },
        "rules": {
          "type": "object",
          "additionalProperties": {
            "enum": ["error", "warning", "info", "off"]
          }
        }
      },
      "additionalProperties": false
    },
    "sourceRoots": {
      "type": "array",
      "items": { "type": "string" }
    },
    "sourceGlobs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "sourceAnnotations": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean", "default": false },
        "sourceRoots": {
          "type": "array",
          "items": { "type": "string" }
        },
        "sourceGlobs": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "plugins": {
      "type": "array",
      "items": { "type": "string" }
    },
    "exclude": {
      "type": "array",
      "items": { "type": "string" }
    },
    "driftResolvers": {
      "type": "array",
      "items": { "type": "string" }
    },
    "hooks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["event", "run"],
        "properties": {
          "event": { "type": "string" },
          "run": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "testMetadata": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "testGlobs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "requirementPattern": {
          "oneOf": [
            { "type": "string" },
            {
              "type": "array",
              "items": { "type": "string" }
            }
          ]
        }
      }
    },
    "workflowPolicyPath": {
      "type": "string",
      "default": "docs/workflow-policy.yaml"
    },
    "customChangeTypes": {
      "type": "array",
      "items": { "type": "string" }
    },
    "versionPolicy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "defaultCompatibility": {
          "type": "string",
          "enum": ["backward-only", "full", "breaking-allowed", "frozen"]
        },
        "perSchema": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "compatibility": {
                "type": "string",
                "enum": ["backward-only", "full", "breaking-allowed", "frozen"]
              },
              "deprecationWindow": {
                "type": "string",
                "pattern": "^\\d+(d|m|y)$"
              }
            }
          }
        },
        "perDomain": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "compatibility": {
                "type": "string",
                "enum": ["backward-only", "full", "breaking-allowed", "frozen"]
              },
              "deprecationWindow": {
                "type": "string",
                "pattern": "^\\d+(d|m|y)$"
              }
            }
          }
        }
      }
    },
    "entityMode": {
      "type": "string",
      "enum": ["manifest", "inline"]
    },
    "manifestPath": {
      "type": "string",
      "default": "catalog-info.yaml"
    },
    "catalogDir": {
      "type": "string",
      "default": "catalog"
    },
    "inlineDocDirs": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
