{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://anchored-spec.dev/schemas/ea/technology-standard.schema.json",
  "title": "Anchored Spec — EA Technology Standard",
  "description": "An approved technology standard.",
  "allOf": [
    { "$ref": "https://anchored-spec.dev/schemas/ea/entity-base.schema.json" }
  ],
  "required": ["category", "technology"],
  "properties": {
    "kind": { "const": "technology-standard" },
    "category": {
      "type": "string",
      "enum": ["language", "framework", "database", "messaging", "runtime", "cloud-service", "tool", "protocol", "other"],
      "description": "Technology category"
    },
    "technology": {
      "type": "string",
      "minLength": 1,
      "description": "Technology name (e.g., PostgreSQL, TypeScript, Kafka)"
    },
    "approvedVersions": {
      "type": "array",
      "items": { "type": "string" },
      "description": "List of approved versions"
    },
    "deprecatedVersions": {
      "type": "array",
      "items": { "type": "string" },
      "description": "List of deprecated versions"
    },
    "scope": {
      "type": "object",
      "properties": {
        "domains": { "type": "array", "items": { "type": "string" } },
        "environments": { "type": "array", "items": { "type": "string" } },
        "teams": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false,
      "description": "Where this standard applies"
    },
    "approvedAt": {
      "type": "string",
      "description": "ISO 8601 timestamp of approval"
    },
    "reviewBy": {
      "type": "string",
      "description": "ISO 8601 timestamp for next review"
    },
    "alternatives": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Artifact IDs of alternative standards"
    },
    "rationale": {
      "type": "string",
      "description": "Why this technology was standardized"
    }
  }
}
