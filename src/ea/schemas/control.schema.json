{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://anchored-spec.dev/schemas/ea/control.schema.json",
  "title": "Anchored Spec — EA Control",
  "description": "A governance control with type, implementation, assertion, and enforcement.",
  "allOf": [
    { "$ref": "https://anchored-spec.dev/schemas/ea/artifact-base.schema.json" }
  ],
  "required": ["controlType", "implementation", "assertion"],
  "properties": {
    "kind": { "const": "control" },
    "controlType": {
      "type": "string",
      "enum": ["preventive", "detective", "corrective", "directive"],
      "description": "Control type"
    },
    "implementation": {
      "type": "string",
      "enum": ["automated", "manual", "hybrid"],
      "description": "Implementation method"
    },
    "assertion": { "type": "string", "minLength": 1, "description": "What this control asserts" },
    "mechanism": { "type": "string", "description": "How the control operates" },
    "frequency": {
      "type": "string",
      "enum": ["continuous", "hourly", "daily", "weekly", "monthly", "on-demand", "event-triggered"],
      "description": "Execution frequency"
    },
    "producesEvidence": { "type": "string", "description": "Evidence artifact reference" },
    "onViolation": {
      "type": "object",
      "required": ["action"],
      "properties": {
        "action": {
          "type": "string",
          "enum": ["block", "alert", "escalate", "log", "auto-remediate"]
        },
        "target": { "type": "string" },
        "description": { "type": "string" }
      },
      "additionalProperties": false,
      "description": "Violation response"
    },
    "lastExecutedAt": { "type": "string", "description": "ISO 8601 timestamp of last execution" },
    "frameworks": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Compliance frameworks (SOC2, ISO27001, etc.)"
    }
  }
}
