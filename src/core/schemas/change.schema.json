{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://anchored-spec.dev/schemas/change.schema.json",
  "title": "Anchored Spec — Change Record",
  "description": "A change record tracking an implementation effort. Changes are born technical — they carry file scope, affected symbols, and policy enforcement.",
  "type": "object",
  "required": [
    "id",
    "title",
    "slug",
    "type",
    "phase",
    "status",
    "scope",
    "branch",
    "timestamps",
    "owners"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "description": "JSON Schema reference for editor validation"
    },
    "id": {
      "type": "string",
      "pattern": "^CHG-[0-9]{4}-[0-9]{4}-[a-z0-9]+(?:-[a-z0-9]+)*$",
      "description": "Year-sequenced ID with human-readable slug"
    },
    "title": {
      "type": "string",
      "minLength": 5,
      "maxLength": 120
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
      "description": "URL-safe short name"
    },
    "type": {
      "type": "string",
      "enum": ["feature", "fix", "refactor", "chore"],
      "description": "Change type — determines workflow variant"
    },
    "workflowVariant": {
      "type": "string",
      "description": "Which workflow variant governs this change"
    },
    "phase": {
      "type": "string",
      "enum": ["design", "planned", "implementation", "verification", "done", "archived"],
      "description": "Current lifecycle phase"
    },
    "status": {
      "type": "string",
      "enum": ["active", "blocked", "complete", "cancelled"],
      "description": "Execution status"
    },
    "scope": {
      "type": "object",
      "required": ["include"],
      "properties": {
        "include": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1,
          "description": "Glob patterns for files in scope"
        },
        "exclude": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Glob patterns for files excluded from scope"
        }
      },
      "additionalProperties": false
    },
    "requirements": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^REQ-[1-9][0-9]*$"
      },
      "description": "Requirement IDs this change implements"
    },
    "branch": {
      "type": ["string", "null"],
      "description": "Git branch name (null if not yet created)"
    },
    "timestamps": {
      "type": "object",
      "required": ["createdAt"],
      "properties": {
        "createdAt": {
          "type": "string",
          "format": "date",
          "description": "ISO 8601 date"
        },
        "updatedAt": {
          "type": "string",
          "format": "date"
        }
      },
      "additionalProperties": false
    },
    "owners": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "designDoc": {
      "type": ["string", "null"],
      "description": "Path to design document"
    },
    "implementationPlan": {
      "type": ["string", "null"],
      "description": "Path to implementation plan"
    },
    "bugfixSpec": {
      "type": "object",
      "properties": {
        "currentBehavior": { "type": "string" },
        "expectedBehavior": { "type": "string" },
        "rootCauseHypothesis": { "type": "string" },
        "regressionRisk": { "type": "string" }
      },
      "required": ["currentBehavior", "expectedBehavior"],
      "additionalProperties": false,
      "description": "Required for fix-type changes"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "docSource": {
      "type": "string",
      "const": "canonical-json"
    },
    "schemaVersion": {
      "type": "string",
      "description": "Schema version for migration tracking"
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true,
      "description": "Project-specific custom fields"
    }
  },
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": { "type": { "not": { "const": "chore" } } }
      },
      "then": {
        "required": ["workflowVariant", "requirements"]
      }
    },
    {
      "if": {
        "properties": { "type": { "const": "fix" } }
      },
      "then": {
        "required": ["bugfixSpec"]
      }
    },
    {
      "if": {
        "properties": { "status": { "const": "complete" } }
      },
      "then": {
        "properties": {
          "phase": { "enum": ["done", "archived"] }
        }
      }
    }
  ]
}
