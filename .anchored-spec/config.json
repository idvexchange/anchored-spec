{
  "schemaVersion": "1.2",
  "rootDir": "docs",
  "generatedDir": "docs/generated",
  "idPrefix": null,
  "domains": [
    "systems",
    "delivery",
    "data",
    "information",
    "business",
    "transitions"
  ],
  "docs": {
    "structure": "architecture-views",
    "scanDirs": [
      "docs"
    ],
    "rootDocs": [
