{
  "schemaVersion": "1.0",
  "rootDir": "ea",
  "generatedDir": "ea/generated",
  "domains": {
    "systems": "ea/systems",
    "delivery": "ea/delivery",
    "data": "ea/data",
    "information": "ea/information",
    "business": "ea/business",
    "transitions": "ea/transitions"
  },
  "sourceRoots": ["app", "components", "lib"],
  "sourceGlobs": ["app/**/*.ts", "app/**/*.tsx", "components/**/*.tsx", "lib/**/*.ts"],
  "quality": {
    "requireOwners": true,
    "requireSummary": true,
    "requireRelations": true,
    "requireAnchors": false,
    "strictMode": false
  },
  "versionPolicy": {
    "defaultCompatibility": "backward-only",
    "perKind": {
      "api-contract": { "compatibility": "backward-only" },
      "canonical-entity": { "compatibility": "full" },
      "capability": { "compatibility": "breaking-allowed" }
    }
  },
  "workflowPolicyPath": "ea/workflow-policy.yaml",
  "plugins": [],
  "resolvers": [
    { "name": "openapi" },
    { "name": "tree-sitter", "options": { "queryPacks": ["javascript"] } },
    { "name": "markdown" }
  ],
  "exclude": ["node_modules", ".next", "public"]
}
